{
  "name": "casa-cr-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-next-worker-config.mjs",
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "seed": "npm run seed --workspace backend",
    "seed:samples": "npm run seed:samples --workspace backend",
    "alerts:send": "npm run alerts:send --workspace backend",
    "backup:mongo": "node scripts/mongo-backup.mjs",
    "lint": "npm run lint --workspace backend && npm run lint --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "mapbox-gl": "^3.20.0"
  }
}
